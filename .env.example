# ── ClaudeSec Environment Variables ──────────────────────────────────────
# All variables are optional — sensible defaults are used when unset.

# ── Server ──────────────────────────────────────────────────────────────
CLAUDESEC_PORT=3000

# ── Retention ───────────────────────────────────────────────────────────
CLAUDESEC_MAX_SPANS=50000          # Max spans before oldest are pruned
CLAUDESEC_RETENTION_DAYS=30        # Delete spans older than N days

# ── Rate limiting (per IP on /v1/traces) ────────────────────────────────
CLAUDESEC_RATE_LIMIT_RPS=50        # Requests per second
CLAUDESEC_RATE_LIMIT_BURST=200     # Burst capacity
CLAUDESEC_MAX_SPANS_BATCH=500      # Max spans per single POST

# ── Webhook alerts ──────────────────────────────────────────────────────
# CLAUDESEC_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# CLAUDESEC_WEBHOOK_THRESHOLD=high   # Minimum severity: low | medium | high

# ── OTLP trace forwarding (transparent proxy) ──────────────────────────
# Forward all ingested traces to an upstream OTLP collector
# OTEL_FORWARD_URL=http://localhost:4318/v1/traces

# ── Auto-export ─────────────────────────────────────────────────────────
# CLAUDESEC_AUTO_EXPORT_DIR=./exports   # Hourly JSON snapshots (last 24 kept)
