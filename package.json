  "repository": {
    "type": "git",
    "url": "git+https://github.com/aanjaneyasinghdhoni/ClaudeSec.git"
  },
  "bugs": {
    "url": "https://github.com/aanjaneyasinghdhoni/ClaudeSec/issues"
  },
  "keywords": [
    "ai-agent",
    "observability",
    "opentelemetry",
    "otlp",
    "security",
    "claude-code",
    "copilot",
    "agentic",
    "visualization",
    "threat-detection",
    "local-observatory",
    "mcp"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
